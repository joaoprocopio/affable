{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "affable/core",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13.0",
        "pda/pheanstalk": "^8.0"
    },
    "require-dev": {
        "laravel/pail": "^1.2",
        "laravel/tinker": "^3.0",
        "nunomaduro/collision": "^8.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
